# =============================================
# SERVER
# =============================================
PORT=5000
NODE_ENV=development

# =============================================
# MONGODB
# =============================================
MONGO_URI=mongodb://localhost:27017/saas_backend

# =============================================
# JWT
# =============================================
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# BCRYPT
# =============================================
BCRYPT_SALT_ROUNDS=12

# =============================================
# LOGIN PROTECTION
# =============================================
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# =============================================
# PERMISSIONS (comma-separated, no spaces)
# =============================================
PERMISSIONS=CREATE_BOOK,UPDATE_BOOK,DELETE_BOOK,VIEW_USERS,MANAGE_ORDERS,MANAGE_INVENTORY,VIEW_REPORTS,MANAGE_SETTINGS,MANAGE_CATEGORIES,MANAGE_PRODUCTION,MANAGE_VENDORS,MANAGE_MATERIALS,MANAGE_DISCOUNTS,MANAGE_ROLES,VIEW_LOGS

# =============================================
# CORS
# =============================================
CLIENT_URL=http://localhost:5174

# =============================================
# LOGGING
# =============================================
LOG_LEVEL=info

SUPER_ADMIN_EMAIL=admin@example.com
